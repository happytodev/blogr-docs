{
    "name": "happytodev/blogr-docs",
    "version": "2.0.2",
    "description": "Documentation system plugin for Blogr \u2014 hierarchical docs, learning paths, media embeds, PDF export",
    "type": "filament-plugin",
    "license": "MIT",
    "authors": [
        {
            "name": "Frederic Blanc",
            "email": "frederic.blanc@happytodev.com",
            "role": "Developer"
        }
    ],
    "repositories": [
        {
            "type": "path",
            "url": "../blogr"
        }
    ],
    "require": {
        "php": "^8.3",
        "happytodev/blogr": "*",
        "spatie/laravel-package-tools": "^1.15.0",
        "filament/filament": "^5.0",
        "filament/actions": "^5.0",
        "filament/schemas": "^5.0",
        "filament/support": "^5.0",
        "filament/tables": "^5.0",
        "league/commonmark": "^2.6",
        "barryvdh/laravel-dompdf": "^3.1"
    },
    "require-dev": {
        "orchestra/testbench": "^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "larastan/larastan": "^3.10",
        "laravel/pint": "^1.29"
    },
    "autoload": {
        "psr-4": {
            "Happytodev\\BlogrDocs\\": "src/",
            "Happytodev\\BlogrDocs\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Happytodev\\BlogrDocs\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "lint": "vendor/bin/pint",
        "analyse": "vendor/bin/phpstan analyse --memory-limit=2G"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Happytodev\\BlogrDocs\\BlogrDocsServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "pestphp/pest-plugin-arch": true,
            "pestphp/pest-plugin-laravel": true
        }
    }
}
